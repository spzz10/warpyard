# Warpyard configuration — copy to `.env` (dev) or `/opt/warpyard/.env.local` (prod)
# and fill in. Every value here overrides a default in app/config.py.

# ── Database ────────────────────────────────────────────────────────────────
# sqlite is fine for kicking the tires; prod uses Postgres (see deploy/provision-cp.sh)
DATABASE_URL=sqlite:///./warpyard.db
#DATABASE_URL=postgresql://warpyard:CHANGE-ME@localhost:5432/warpyard

# Signs session cookies AND password-reset tokens (any long random string, e.g.
# `openssl rand -hex 32`). REQUIRED in prod. Unset = a random per-process secret
# (dev only — restarts log everyone out and void outstanding reset links).
#SESSION_SECRET=

# ── Identity ────────────────────────────────────────────────────────────────
BASE_DOMAIN=example.com                  # tenant servers live at <name>.BASE_DOMAIN
PUBLIC_URL=https://app.example.com       # the dashboard's public URL
MCP_URL=https://mcp.example.com          # the MCP server's public URL

# ── Proxmox (tenant hypervisor) ─────────────────────────────────────────────
# Roles/tokens setup: docs/PVE-SETUP.md. Token form: user@pve!tokenid=uuid
PROXMOX_API_URL=https://YOUR-PVE-HOST:8006
PROXMOX_NODE=pve
PROXMOX_POOL=tenants
PROXMOX_VERIFY_TLS=false
PROXMOX_TOKEN_POWER=
PROXMOX_TOKEN_CONFIG=
PROXMOX_TOKEN_CONSOLE=
PROXMOX_TOKEN_BACKUP=

# Storage tenant disks are cloned onto. Point at a ZFS-encrypted dataset's storage
# entry to offer at-rest encryption (docs/PVE-SETUP.md).
TENANT_STORAGE=local-zfs
# Cloud-init vendor snippet for TLS-passthrough web servers (deploy/snippets/wy-tls.yml)
TLS_SNIPPET=vendor=local:snippets/wy-tls.yml

# ── Tenant network (docs/NETWORK.md) ────────────────────────────────────────
TENANT_BRIDGE=vmbr0
TENANT_VLAN_TAG=66
TENANT_GATEWAY=10.66.0.1
TENANT_NAMESERVERS=1.1.1.1 8.8.8.8
EDGE_WG_IP=10.10.66.2                    # the edge's WireGuard address
CONTROL_PLANE_IP=                        # this machine's IP as seen from the tenant VLAN

# ── Edge (public ingress VPS) ───────────────────────────────────────────────
EDGE_HOST=edge.example.com               # public name of the edge box
EDGE_IP=                                 # its public IP (custom-domain DNS pre-checks)
EDGE_SYNC_TOKEN=                         # shared secret the edge agent authenticates with

# ── Backups (optional — Proxmox Backup Server) ──────────────────────────────
#BACKUP_STORAGE=warpyard-pbs
#BACKUP_HOUR_UTC=8
#PBS_API_URL=https://YOUR-PBS-HOST:8007
#PBS_DATASTORE=warpyard
#PBS_TOKEN=

# ── Email (optional — Resend). Unset = links shown in the UI instead ────────
#WARPYARD_RESEND_TOKEN=
#MAIL_FROM=Warpyard <invites@example.com>

# ── Uptime monitoring (optional — PoppaPing) ────────────────────────────────
#POPPAPING_BASE_URL=https://poppaping.com
#WARPYARD_POPPAPING_PARTNER_SECRET=
